# Server
HOST=0.0.0.0
PORT=8000

# How often to poll data sources (minutes)
COLLECTION_INTERVAL_MINUTES=15

# Optional: Cloudflare Radar free API token
# Get one at: dash.cloudflare.com -> My Profile -> API Tokens
CLOUDFLARE_API_TOKEN=

# Optional: Discord webhook URL for significant-event alerts
ALERT_WEBHOOK_URL=

# Optional: auto-post significant events to Mastodon.
# Token: your instance -> Preferences -> Development -> New application
# (only the write:statuses scope is needed).
MASTODON_INSTANCE_URL=
MASTODON_ACCESS_TOKEN=
# public | unlisted | private (default: public)
MASTODON_VISIBILITY=public

# Optional: public base URL of this site (e.g. https://outages.example.com),
# appended as a link in social posts
PUBLIC_SITE_URL=

# Optional: site hashtag appended to social posts (auto Mastodon posts and
# the frontend Share button), e.g. #PartiallyOnline
SITE_HASHTAG=

# ── Advertising ──────────────────────────────────────────
# Only placement parameters (IDs, URLs) — never raw HTML/scripts.
# The frontend constructs tags from these validated values.
#
# Google (AdSense)
SPONSOR_GOOGLE_ID=
SPONSOR_GOOGLE_SLOTS={"header":"1234567890","sidebar":"0987654321"}
#
# Custom sponsor scripts (HilltopAds, etc). JSON map of {placement: script_url}.
# URLs must start with https:// or // (protocol-relative).
# The backend validates the URL and auto-adds the domain to CSP.
# Example (HilltopAds):
SPONSOR_SCRIPTS={"header":"//unfoldedtrade.com/bpXEV.s/d/G/lT0XYhWqcF/keemh9-uzZmUVljkZPqT/cvyEM/zhIK4TN/TgMXtZNJzJI/zLMyjngs1yNowQ"}

# ── Security ──────────────────────────────────────────────
# Admin key required for POST /api/admin/refresh and /api/admin/probe
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=

# CORS: comma-separated allowed origins (* = public read access)
ALLOWED_ORIGINS=*
