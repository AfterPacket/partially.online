# Server
HOST=0.0.0.0
PORT=8000

# How often to poll data sources (minutes)
COLLECTION_INTERVAL_MINUTES=15

# Optional: Cloudflare Radar free API token
# Get one at: dash.cloudflare.com -> My Profile -> API Tokens
CLOUDFLARE_API_TOKEN=

# Optional: Discord webhook URL for significant-event alerts
ALERT_WEBHOOK_URL=

# ── Security ──────────────────────────────────────────────
# Admin key required for POST /api/admin/refresh and /api/admin/probe
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=

# CORS: comma-separated allowed origins (* = public read access)
ALLOWED_ORIGINS=*
